{
	"name": "tambourine-voice",
	"version": "0.1.0",
	"type": "module",
	"description": "Your personal voice interface for any app",
	"scripts": {
		"dev": "tauri dev",
		"dev:vite": "vite",
		"build": "tauri build",
		"build:vite": "vite build",
		"lint": "biome check --write",
		"typecheck": "tsc --noEmit",
		"knip": "knip",
		"test": "vitest run --reporter=dot",
		"test:watch": "vitest",
		"cargo:clippy": "cargo clippy --all-targets --all-features --locked --manifest-path src-tauri/Cargo.toml",
		"cargo:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
		"cargo:test": "cargo test --quiet --locked --manifest-path src-tauri/Cargo.toml",
		"cargo:check": "pnpm run cargo:clippy && pnpm run cargo:fmt && pnpm run cargo:test",
		"cargo:upgrade": "cargo upgrade --manifest-path src-tauri/Cargo.toml",
		"cargo:update": "cargo update --manifest-path src-tauri/Cargo.toml",
		"update": "pnpm update --latest && pnpm run cargo:upgrade && pnpm run cargo:update",
		"check": "pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm test && pnpm run cargo:check",
		"tauri": "tauri"
	},
	"author": "kstonekuan",
	"license": "AGPL-3.0",
	"dependencies": {
		"@daily-co/daily-js": "^0.89.1",
		"@mantine/core": "^9.0.2",
		"@mantine/hooks": "^9.0.2",
		"@mantine/notifications": "^9.0.2",
		"@pipecat-ai/client-js": "^1.7.0",
		"@pipecat-ai/client-react": "^1.2.1",
		"@pipecat-ai/small-webrtc-transport": "^1.10.0",
		"@pipecat-ai/voice-ui-kit": "^0.8.2",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-query": "^5.99.0",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "^2.7.0",
		"@tauri-apps/plugin-fs": "^2.5.0",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-store": "^2.4.2",
		"@use-gesture/react": "^10.3.1",
		"@xstate/react": "^6.1.0",
		"date-fns": "^4.1.0",
		"ky": "^2.0.1",
		"lucide-react": "^1.8.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hotkeys-hook": "^5.2.4",
		"tailwindcss": "4.2.2",
		"ts-pattern": "^5.9.0",
		"xstate": "^5.30.0",
		"zod": "4.3.6",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@tauri-apps/cli": "2.10.1",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"knip": "6.4.1",
		"typescript": "6.0.2",
		"vite": "8.0.8",
		"vite-plugin-svgr": "5.2.0",
		"vitest": "4.1.4"
	}
}
